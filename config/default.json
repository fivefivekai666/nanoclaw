{
  "agent": {
    "name": "myagent",
    "workspace": "./workspace",
    "system_prompt": "You are a helpful assistant.",
    "identity_name": "myagent",
    "identity_role": "teaching-oriented agent runtime",
    "persona_style": "clear, calm, structured",
    "response_style": "normal",
    "default_session_id": "local-dev-session",
    "session_dir": "workspace/sessions",
    "retry": {
      "max_attempts": 2,
      "retry_on_recoverable_only": true
    }
  },
  "provider": {
    "name": "mock",
    "model": "mock-echo-v1",
    "fallback": {
      "enabled": true,
      "name": "mock",
      "model": "mock-fallback-v1",
      "on_recoverable_only": true
    }
  }
}
